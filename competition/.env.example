# =============================================================================
# LLM Configuration — Set at least ONE of these backends
# =============================================================================

# --- OPTION 1: Local University LLM Service (primary) ---
# The university GPU cluster running Qwen2.5-72B-Instruct.
# You need an SSH tunnel running (see README).
LLM_SERVICE_URL=https://uhhpc.herts.ac.uk/qwen
LLM_API_TOKEN=your-token-here

# --- OPTION 2: Google Gemini (free fallback) ---
# Sign up at https://aistudio.google.com → Get API Key
# This is FREE and works as a backup if the local service is down.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
